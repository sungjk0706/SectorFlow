# SectorFlow — 로컬 데스크톱 (선택)
# 이 파일을 복사해 프로젝트 루트에 `.env` 로 저장한 뒤 값을 넣습니다.
# 키움·텔레그램 계정 값은 주로 앱이 `backend/data/settings.json` 에 저장합니다.

# 암호화 (settings.json 의 민감 필드 복호화에 사용)
# Fernet: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# 로그 레벨: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
